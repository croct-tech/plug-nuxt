{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "#app": ["./node_modules/nuxt/dist/app"],
      "#imports": ["./e2e/app/.nuxt/types/nitro-imports"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "e2e/**/*.ts",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "e2e/app",
    "src/runtime/server",
    "test/runtime/server"
  ]
}
